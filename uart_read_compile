# Имя исполняемого файла
TARGET = uart_read

# Исходные файлы
SOURCES = uart_read.cpp

# Компилятор и флаги
CXX = g++
CXXFLAGS = -O2 -Wall
#LDFLAGS = -lwiringPi -lsfml-graphics -lsfml-window -lsfml-system
LDFLAGS = -lwiringPi

# Правило сборки
$(TARGET): $(SOURCES)
	$(CXX) $(CXXFLAGS) -o $(TARGET) $(SOURCES) $(LDFLAGS)

# Очистка
clean:
	rm -f $(TARGET)

