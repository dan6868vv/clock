# Имя исполняемого файла
TARGET = clock_program

# Исходные файлы
SOURCES = main.cpp

# Компилятор и флаги
CXX = g++
CXXFLAGS = -O2 -Wall
LDFLAGS = -I/home/andrey/raylib/src -L/home/andrey/raylib/src -lraylib -ldrm -lgbm -lEGL -lGLESv2 -lm -lpthread -ldl -lrt

# Правило сборки
$(TARGET): $(SOURCES)
	$(CXX) -D__unix__ $(CXXFLAGS) -o $(TARGET) $(SOURCES) $(LDFLAGS)

# Очистка
clean:
	rm -f $(TARGET)